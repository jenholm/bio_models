archive/

# ============================================================
# Explicitly retain arXiv source assets
# ============================================================
!arxiv/
!arxiv/manuscript/
!arxiv/latex/
!arxiv/supplementary/
!arxiv/review/
!arxiv/reproducibility/
!arxiv/latex/*.tex
!arxiv/latex/*.bib
!arxiv/manuscript/*.md
!arxiv/supplementary/*.md
!arxiv/reproducibility/*.yml
!arxiv/reproducibility/*.txt
!arxiv/reproducibility/*.sh
!arxiv/reproducibility/*.md

# Retain paper review framework
!paper/internal/

# Retain paper working notes
!paper_working/notes/
!paper_working/empirical_proxy/
!paper_working/references.bib

# Publication PDFs intentionally tracked
!arxiv/
!arxiv/latex/
!arxiv/latex/figures/
!arxiv/figures/
!arxiv/figures/final/

!arxiv/latex/hsap.pdf
!arxiv/latex/figures/*.pdf
!arxiv/figures/final/*.pdf
